{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.routepilot.dev/v1/artifacts/validation-report.v1.schema.json",
  "x-routepilot-contract": "ValidationReport@1",
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_type": {
          "enum": [
            "user",
            "agent",
            "service",
            "migration"
          ],
          "title": "Actor Type",
          "type": "string"
        },
        "actor_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Actor Id",
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "artifact_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_type",
        "artifact_id",
        "schema_version",
        "version"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ArtifactType": {
      "enum": [
        "TripBrief",
        "EvidenceBundle",
        "CandidateSet",
        "ItineraryPlan",
        "ConstraintReport",
        "SemanticRiskReport",
        "ValidationReport",
        "TripSnapshot",
        "ShareSnapshot"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "ValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "issue_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Issue Id",
          "type": "string"
        },
        "origin": {
          "enum": [
            "constraint",
            "semantic",
            "policy"
          ],
          "title": "Origin",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "message": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "source_report_ref": {
          "$ref": "#/$defs/ArtifactRef"
        }
      },
      "required": [
        "issue_id",
        "origin",
        "severity",
        "message",
        "source_report_ref"
      ],
      "title": "ValidationIssue",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Artifact Id",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "reason": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "artifact_type": {
      "const": "ValidationReport",
      "title": "Artifact Type",
      "type": "string"
    },
    "plan_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "constraint_report_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "semantic_risk_report_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "timezone": {
      "examples": [
        "Asia/Shanghai"
      ],
      "format": "iana-time-zone",
      "maxLength": 64,
      "minLength": 1,
      "title": "Timezone",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "policy_version": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Policy Version",
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "warning",
        "fail"
      ],
      "title": "Verdict",
      "type": "string"
    },
    "publishable": {
      "title": "Publishable",
      "type": "boolean"
    },
    "blockers": {
      "items": {
        "$ref": "#/$defs/ValidationIssue"
      },
      "maxItems": 500,
      "title": "Blockers",
      "type": "array"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/ValidationIssue"
      },
      "maxItems": 500,
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "artifact_id",
    "schema_version",
    "version",
    "created_at",
    "created_by",
    "reason",
    "artifact_type",
    "plan_ref",
    "constraint_report_ref",
    "semantic_risk_report_ref",
    "timezone",
    "generated_at",
    "policy_version",
    "verdict",
    "publishable"
  ],
  "title": "ValidationReport",
  "type": "object"
}
