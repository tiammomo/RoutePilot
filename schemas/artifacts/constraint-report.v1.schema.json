{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.routepilot.dev/v1/artifacts/constraint-report.v1.schema.json",
  "x-routepilot-contract": "ConstraintReport@1",
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_type": {
          "enum": [
            "user",
            "agent",
            "service",
            "migration"
          ],
          "title": "Actor Type",
          "type": "string"
        },
        "actor_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Actor Id",
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "artifact_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_type",
        "artifact_id",
        "schema_version",
        "version"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ArtifactType": {
      "enum": [
        "TripBrief",
        "EvidenceBundle",
        "CandidateSet",
        "ItineraryPlan",
        "ConstraintReport",
        "SemanticRiskReport",
        "ValidationReport",
        "TripSnapshot",
        "ShareSnapshot"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "CheckSummary": {
      "additionalProperties": false,
      "properties": {
        "passed": {
          "minimum": 0,
          "title": "Passed",
          "type": "integer"
        },
        "warnings": {
          "minimum": 0,
          "title": "Warnings",
          "type": "integer"
        },
        "failed": {
          "minimum": 0,
          "title": "Failed",
          "type": "integer"
        }
      },
      "required": [
        "passed",
        "warnings",
        "failed"
      ],
      "title": "CheckSummary",
      "type": "object"
    },
    "ConstraintCheck": {
      "additionalProperties": false,
      "properties": {
        "check_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Check Id",
          "type": "string"
        },
        "constraint_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Constraint Ref"
        },
        "category": {
          "enum": [
            "time",
            "route",
            "budget",
            "opening_hours",
            "hard_constraint"
          ],
          "title": "Category",
          "type": "string"
        },
        "outcome": {
          "enum": [
            "pass",
            "warning",
            "fail"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "message": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        },
        "related_block_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
            "type": "string"
          },
          "maxItems": 100,
          "title": "Related Block Ids",
          "type": "array"
        },
        "observations": {
          "items": {
            "$ref": "#/$defs/MetricObservation"
          },
          "maxItems": 30,
          "title": "Observations",
          "type": "array"
        }
      },
      "required": [
        "check_id",
        "category",
        "outcome",
        "message",
        "source"
      ],
      "title": "ConstraintCheck",
      "type": "object"
    },
    "MetricObservation": {
      "additionalProperties": false,
      "properties": {
        "metric": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "value": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "unit": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "metric",
        "value",
        "unit"
      ],
      "title": "MetricObservation",
      "type": "object"
    },
    "SourceKind": {
      "enum": [
        "user",
        "rag",
        "provider",
        "agent",
        "policy",
        "system"
      ],
      "title": "SourceKind",
      "type": "string"
    },
    "SourceRef": {
      "additionalProperties": false,
      "description": "A safe, versioned provenance pointer; never contains provider raw payloads.",
      "properties": {
        "source_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Source Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "uri": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "publisher": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Publisher"
        },
        "license": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        }
      },
      "required": [
        "source_id",
        "kind",
        "name",
        "version",
        "retrieved_at"
      ],
      "title": "SourceRef",
      "type": "object"
    },
    "VersionedComponent": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "VersionedComponent",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Artifact Id",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "reason": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "artifact_type": {
      "const": "ConstraintReport",
      "title": "Artifact Type",
      "type": "string"
    },
    "plan_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "timezone": {
      "examples": [
        "Asia/Shanghai"
      ],
      "format": "iana-time-zone",
      "maxLength": 64,
      "minLength": 1,
      "title": "Timezone",
      "type": "string"
    },
    "checked_at": {
      "format": "date-time",
      "title": "Checked At",
      "type": "string"
    },
    "engine": {
      "$ref": "#/$defs/VersionedComponent"
    },
    "outcome": {
      "enum": [
        "pass",
        "warning",
        "fail"
      ],
      "title": "Outcome",
      "type": "string"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/ConstraintCheck"
      },
      "maxItems": 2000,
      "minItems": 1,
      "title": "Checks",
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/CheckSummary"
    }
  },
  "required": [
    "artifact_id",
    "schema_version",
    "version",
    "created_at",
    "created_by",
    "reason",
    "artifact_type",
    "plan_ref",
    "timezone",
    "checked_at",
    "engine",
    "outcome",
    "checks",
    "summary"
  ],
  "title": "ConstraintReport",
  "type": "object"
}
