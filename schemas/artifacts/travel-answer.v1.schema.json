{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.routepilot.dev/v1/artifacts/travel-answer.v1.schema.json",
  "x-routepilot-contract": "TravelAnswer@1",
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_type": {
          "enum": [
            "user",
            "agent",
            "service",
            "migration"
          ],
          "title": "Actor Type",
          "type": "string"
        },
        "actor_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Actor Id",
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "AnswerEvidence": {
      "additionalProperties": false,
      "description": "A browser-safe evidence excerpt used by one grounded answer.",
      "properties": {
        "evidence_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Evidence Id",
          "type": "string"
        },
        "title": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "statement": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Statement",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        },
        "freshness": {
          "$ref": "#/$defs/Freshness"
        }
      },
      "required": [
        "evidence_id",
        "title",
        "statement",
        "source",
        "freshness"
      ],
      "title": "AnswerEvidence",
      "type": "object"
    },
    "AnswerSection": {
      "additionalProperties": false,
      "properties": {
        "heading": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Heading",
          "type": "string"
        },
        "body": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Body",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
            "type": "string"
          },
          "maxItems": 20,
          "title": "Evidence Refs",
          "type": "array"
        }
      },
      "required": [
        "heading",
        "body"
      ],
      "title": "AnswerSection",
      "type": "object"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "artifact_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_type",
        "artifact_id",
        "schema_version",
        "version"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ArtifactType": {
      "enum": [
        "TravelQuestion",
        "TravelAnswer",
        "TripBrief",
        "EvidenceBundle",
        "CandidateSet",
        "ItineraryPlan",
        "ConstraintReport",
        "SemanticRiskReport",
        "ValidationReport",
        "TripSnapshot",
        "ShareSnapshot"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "Citation": {
      "additionalProperties": false,
      "properties": {
        "citation_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Citation Id",
          "type": "string"
        },
        "evidence_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Evidence Id",
          "type": "string"
        },
        "title": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "locator": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "citation_id",
        "evidence_id",
        "title",
        "locator",
        "source"
      ],
      "title": "Citation",
      "type": "object"
    },
    "Freshness": {
      "additionalProperties": false,
      "properties": {
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "valid_until": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid Until"
        },
        "status": {
          "$ref": "#/$defs/FreshnessStatus"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "observed_at",
        "status",
        "source"
      ],
      "title": "Freshness",
      "type": "object"
    },
    "FreshnessStatus": {
      "enum": [
        "fresh",
        "stale",
        "expired",
        "unknown"
      ],
      "title": "FreshnessStatus",
      "type": "string"
    },
    "SourceKind": {
      "enum": [
        "user",
        "rag",
        "provider",
        "agent",
        "policy",
        "system"
      ],
      "title": "SourceKind",
      "type": "string"
    },
    "SourceRef": {
      "additionalProperties": false,
      "description": "A safe, versioned provenance pointer; never contains provider raw payloads.",
      "properties": {
        "source_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Source Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "uri": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "publisher": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Publisher"
        },
        "license": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        }
      },
      "required": [
        "source_id",
        "kind",
        "name",
        "version",
        "retrieved_at"
      ],
      "title": "SourceRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "A concise, grounded answer that can later be converted into a trip plan.",
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Artifact Id",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "reason": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "artifact_type": {
      "const": "TravelAnswer",
      "title": "Artifact Type",
      "type": "string"
    },
    "question_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "question": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Question",
      "type": "string"
    },
    "answer_status": {
      "enum": [
        "answered",
        "needs_clarification",
        "insufficient_evidence"
      ],
      "title": "Answer Status",
      "type": "string"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/AnswerSection"
      },
      "maxItems": 8,
      "title": "Sections",
      "type": "array"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/AnswerEvidence"
      },
      "maxItems": 30,
      "title": "Evidence",
      "type": "array"
    },
    "citations": {
      "items": {
        "$ref": "#/$defs/Citation"
      },
      "maxItems": 100,
      "title": "Citations",
      "type": "array"
    },
    "assumptions": {
      "items": {
        "maxLength": 256,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 20,
      "title": "Assumptions",
      "type": "array"
    },
    "limitations": {
      "items": {
        "maxLength": 2000,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 20,
      "title": "Limitations",
      "type": "array"
    },
    "suggested_questions": {
      "items": {
        "maxLength": 256,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 6,
      "title": "Suggested Questions",
      "type": "array"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "schema_version",
    "version",
    "created_at",
    "created_by",
    "reason",
    "artifact_type",
    "question_ref",
    "question",
    "answer_status",
    "summary",
    "generated_at"
  ],
  "title": "TravelAnswer",
  "type": "object"
}
