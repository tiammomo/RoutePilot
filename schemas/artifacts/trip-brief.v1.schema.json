{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.routepilot.dev/v1/artifacts/trip-brief.v1.schema.json",
  "x-routepilot-contract": "TripBrief@1",
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_type": {
          "enum": [
            "user",
            "agent",
            "service",
            "migration"
          ],
          "title": "Actor Type",
          "type": "string"
        },
        "actor_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Actor Id",
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ClarificationItem": {
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Question Id",
          "type": "string"
        },
        "prompt": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Prompt",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "status": {
          "enum": [
            "open",
            "answered",
            "dismissed"
          ],
          "title": "Status",
          "type": "string"
        },
        "answer": {
          "anyOf": [
            {
              "maxLength": 2000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Answer"
        }
      },
      "required": [
        "question_id",
        "prompt",
        "required",
        "status"
      ],
      "title": "ClarificationItem",
      "type": "object"
    },
    "ConstraintSpec": {
      "additionalProperties": false,
      "properties": {
        "constraint_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Constraint Id",
          "type": "string"
        },
        "constraint_type": {
          "enum": [
            "date",
            "budget",
            "mobility",
            "dietary",
            "lodging",
            "visit",
            "avoid",
            "other"
          ],
          "title": "Constraint Type",
          "type": "string"
        },
        "hard": {
          "title": "Hard",
          "type": "boolean"
        },
        "priority": {
          "maximum": 5,
          "minimum": 1,
          "title": "Priority",
          "type": "integer"
        },
        "description": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "constraint_id",
        "constraint_type",
        "hard",
        "priority",
        "description",
        "source"
      ],
      "title": "ConstraintSpec",
      "type": "object"
    },
    "CoordinateSystem": {
      "enum": [
        "WGS84",
        "GCJ-02",
        "BD-09"
      ],
      "title": "CoordinateSystem",
      "type": "string"
    },
    "GeoPoint": {
      "additionalProperties": false,
      "properties": {
        "latitude": {
          "anyOf": [
            {
              "maximum": 90.0,
              "minimum": -90.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Latitude"
        },
        "longitude": {
          "anyOf": [
            {
              "maximum": 180.0,
              "minimum": -180.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Longitude"
        },
        "coordinate_system": {
          "$ref": "#/$defs/CoordinateSystem"
        },
        "accuracy_meters": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Accuracy Meters"
        }
      },
      "required": [
        "latitude",
        "longitude",
        "coordinate_system"
      ],
      "title": "GeoPoint",
      "type": "object"
    },
    "MoneyRange": {
      "additionalProperties": false,
      "properties": {
        "min_amount": {
          "maxLength": 32,
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,4})?$",
          "title": "Min Amount",
          "type": "string"
        },
        "max_amount": {
          "maxLength": 32,
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,4})?$",
          "title": "Max Amount",
          "type": "string"
        },
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "basis": {
          "enum": [
            "per_person",
            "per_group",
            "per_room",
            "per_item",
            "total"
          ],
          "title": "Basis",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "min_amount",
        "max_amount",
        "currency",
        "basis",
        "observed_at",
        "source"
      ],
      "title": "MoneyRange",
      "type": "object"
    },
    "PlaceRef": {
      "additionalProperties": false,
      "properties": {
        "place_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Place Id",
          "type": "string"
        },
        "display_name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "address": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Address"
        },
        "country_code": {
          "pattern": "^[A-Z]{2}$",
          "title": "Country Code",
          "type": "string"
        },
        "timezone": {
          "examples": [
            "Asia/Shanghai"
          ],
          "format": "iana-time-zone",
          "maxLength": 64,
          "minLength": 1,
          "title": "Timezone",
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/GeoPoint"
        },
        "provider_ids": {
          "items": {
            "$ref": "#/$defs/ProviderPlaceId"
          },
          "maxItems": 16,
          "title": "Provider Ids",
          "type": "array"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "place_id",
        "display_name",
        "country_code",
        "timezone",
        "location",
        "source"
      ],
      "title": "PlaceRef",
      "type": "object"
    },
    "ProviderPlaceId": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "place_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Place Id",
          "type": "string"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "place_id",
        "version"
      ],
      "title": "ProviderPlaceId",
      "type": "object"
    },
    "SourceKind": {
      "enum": [
        "user",
        "rag",
        "provider",
        "agent",
        "policy",
        "system"
      ],
      "title": "SourceKind",
      "type": "string"
    },
    "SourceRef": {
      "additionalProperties": false,
      "description": "A safe, versioned provenance pointer; never contains provider raw payloads.",
      "properties": {
        "source_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Source Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "uri": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "publisher": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Publisher"
        },
        "license": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        }
      },
      "required": [
        "source_id",
        "kind",
        "name",
        "version",
        "retrieved_at"
      ],
      "title": "SourceRef",
      "type": "object"
    },
    "TravelPreference": {
      "additionalProperties": false,
      "properties": {
        "preference_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Preference Id",
          "type": "string"
        },
        "category": {
          "enum": [
            "pace",
            "food",
            "culture",
            "nature",
            "shopping",
            "lodging",
            "mobility",
            "other"
          ],
          "title": "Category",
          "type": "string"
        },
        "value": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "priority": {
          "maximum": 5,
          "minimum": 1,
          "title": "Priority",
          "type": "integer"
        }
      },
      "required": [
        "preference_id",
        "category",
        "value",
        "priority"
      ],
      "title": "TravelPreference",
      "type": "object"
    },
    "TravelerGroup": {
      "additionalProperties": false,
      "properties": {
        "adults": {
          "maximum": 99,
          "minimum": 0,
          "title": "Adults",
          "type": "integer"
        },
        "children_ages": {
          "items": {
            "maximum": 17,
            "minimum": 0,
            "type": "integer"
          },
          "maxItems": 30,
          "title": "Children Ages",
          "type": "array"
        },
        "seniors": {
          "default": 0,
          "maximum": 99,
          "minimum": 0,
          "title": "Seniors",
          "type": "integer"
        },
        "rooms": {
          "default": 0,
          "maximum": 50,
          "minimum": 0,
          "title": "Rooms",
          "type": "integer"
        },
        "accessibility_needs": {
          "items": {
            "maxLength": 256,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 20,
          "title": "Accessibility Needs",
          "type": "array"
        }
      },
      "required": [
        "adults"
      ],
      "title": "TravelerGroup",
      "type": "object"
    },
    "TripDateRange": {
      "additionalProperties": false,
      "properties": {
        "start_date": {
          "format": "date",
          "title": "Start Date",
          "type": "string"
        },
        "end_date": {
          "format": "date",
          "title": "End Date",
          "type": "string"
        },
        "timezone": {
          "examples": [
            "Asia/Shanghai"
          ],
          "format": "iana-time-zone",
          "maxLength": 64,
          "minLength": 1,
          "title": "Timezone",
          "type": "string"
        },
        "flexibility_days": {
          "default": 0,
          "maximum": 31,
          "minimum": 0,
          "title": "Flexibility Days",
          "type": "integer"
        }
      },
      "required": [
        "start_date",
        "end_date",
        "timezone"
      ],
      "title": "TripDateRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Artifact Id",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "reason": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "artifact_type": {
      "const": "TripBrief",
      "title": "Artifact Type",
      "type": "string"
    },
    "destination": {
      "$ref": "#/$defs/PlaceRef"
    },
    "date_window": {
      "$ref": "#/$defs/TripDateRange"
    },
    "travelers": {
      "$ref": "#/$defs/TravelerGroup"
    },
    "budget": {
      "$ref": "#/$defs/MoneyRange"
    },
    "preferences": {
      "items": {
        "$ref": "#/$defs/TravelPreference"
      },
      "maxItems": 50,
      "title": "Preferences",
      "type": "array"
    },
    "constraints": {
      "items": {
        "$ref": "#/$defs/ConstraintSpec"
      },
      "maxItems": 100,
      "title": "Constraints",
      "type": "array"
    },
    "clarification_items": {
      "items": {
        "$ref": "#/$defs/ClarificationItem"
      },
      "maxItems": 30,
      "title": "Clarification Items",
      "type": "array"
    },
    "source": {
      "$ref": "#/$defs/SourceRef"
    }
  },
  "required": [
    "artifact_id",
    "schema_version",
    "version",
    "created_at",
    "created_by",
    "reason",
    "artifact_type",
    "destination",
    "date_window",
    "travelers",
    "budget",
    "source"
  ],
  "title": "TripBrief",
  "type": "object"
}
