{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.routepilot.dev/v1/artifacts/semantic-risk-report.v1.schema.json",
  "x-routepilot-contract": "SemanticRiskReport@1",
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_type": {
          "enum": [
            "user",
            "agent",
            "service",
            "migration"
          ],
          "title": "Actor Type",
          "type": "string"
        },
        "actor_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Actor Id",
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "artifact_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_type",
        "artifact_id",
        "schema_version",
        "version"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ArtifactType": {
      "enum": [
        "TravelQuestion",
        "TravelAnswer",
        "TripBrief",
        "EvidenceBundle",
        "CandidateSet",
        "ItineraryPlan",
        "ConstraintReport",
        "SemanticRiskReport",
        "ValidationReport",
        "TripSnapshot",
        "ShareSnapshot"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "EvidenceConflict": {
      "additionalProperties": false,
      "properties": {
        "conflict_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Conflict Id",
          "type": "string"
        },
        "topic": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Topic",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
            "type": "string"
          },
          "maxItems": 20,
          "minItems": 2,
          "title": "Evidence Refs",
          "type": "array"
        },
        "detail": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "resolution_status": {
          "enum": [
            "unresolved",
            "resolved",
            "accepted_risk"
          ],
          "title": "Resolution Status",
          "type": "string"
        }
      },
      "required": [
        "conflict_id",
        "topic",
        "evidence_refs",
        "detail",
        "resolution_status"
      ],
      "title": "EvidenceConflict",
      "type": "object"
    },
    "EvidenceCoverage": {
      "additionalProperties": false,
      "properties": {
        "claims_total": {
          "minimum": 0,
          "title": "Claims Total",
          "type": "integer"
        },
        "claims_supported": {
          "minimum": 0,
          "title": "Claims Supported",
          "type": "integer"
        },
        "claims_missing": {
          "minimum": 0,
          "title": "Claims Missing",
          "type": "integer"
        },
        "coverage_ratio": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Coverage Ratio"
        }
      },
      "required": [
        "claims_total",
        "claims_supported",
        "claims_missing",
        "coverage_ratio"
      ],
      "title": "EvidenceCoverage",
      "type": "object"
    },
    "SemanticRisk": {
      "additionalProperties": false,
      "properties": {
        "risk_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Risk Id",
          "type": "string"
        },
        "category": {
          "enum": [
            "evidence_gap",
            "assumption",
            "source_conflict",
            "soft_constraint",
            "ambiguity"
          ],
          "title": "Category",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "message": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "affected_block_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
            "type": "string"
          },
          "maxItems": 100,
          "title": "Affected Block Ids",
          "type": "array"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
            "type": "string"
          },
          "maxItems": 100,
          "title": "Evidence Refs",
          "type": "array"
        },
        "suggested_resolution": {
          "anyOf": [
            {
              "maxLength": 2000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suggested Resolution"
        }
      },
      "required": [
        "risk_id",
        "category",
        "severity",
        "message"
      ],
      "title": "SemanticRisk",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SourceKind": {
      "enum": [
        "user",
        "rag",
        "provider",
        "agent",
        "policy",
        "system"
      ],
      "title": "SourceKind",
      "type": "string"
    },
    "SourceRef": {
      "additionalProperties": false,
      "description": "A safe, versioned provenance pointer; never contains provider raw payloads.",
      "properties": {
        "source_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Source Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "uri": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "publisher": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Publisher"
        },
        "license": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        }
      },
      "required": [
        "source_id",
        "kind",
        "name",
        "version",
        "retrieved_at"
      ],
      "title": "SourceRef",
      "type": "object"
    },
    "VersionedComponent": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "VersionedComponent",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Artifact Id",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "reason": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "artifact_type": {
      "const": "SemanticRiskReport",
      "title": "Artifact Type",
      "type": "string"
    },
    "plan_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "evidence_bundle_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "timezone": {
      "examples": [
        "Asia/Shanghai"
      ],
      "format": "iana-time-zone",
      "maxLength": 64,
      "minLength": 1,
      "title": "Timezone",
      "type": "string"
    },
    "assessed_at": {
      "format": "date-time",
      "title": "Assessed At",
      "type": "string"
    },
    "reviewer": {
      "$ref": "#/$defs/VersionedComponent"
    },
    "assessment_source": {
      "$ref": "#/$defs/SourceRef"
    },
    "outcome": {
      "enum": [
        "pass",
        "warning",
        "fail"
      ],
      "title": "Outcome",
      "type": "string"
    },
    "evidence_coverage": {
      "$ref": "#/$defs/EvidenceCoverage"
    },
    "risks": {
      "items": {
        "$ref": "#/$defs/SemanticRisk"
      },
      "maxItems": 1000,
      "title": "Risks",
      "type": "array"
    },
    "source_conflicts": {
      "items": {
        "$ref": "#/$defs/EvidenceConflict"
      },
      "maxItems": 200,
      "title": "Source Conflicts",
      "type": "array"
    }
  },
  "required": [
    "artifact_id",
    "schema_version",
    "version",
    "created_at",
    "created_by",
    "reason",
    "artifact_type",
    "plan_ref",
    "evidence_bundle_ref",
    "timezone",
    "assessed_at",
    "reviewer",
    "assessment_source",
    "outcome",
    "evidence_coverage"
  ],
  "title": "SemanticRiskReport",
  "type": "object"
}
