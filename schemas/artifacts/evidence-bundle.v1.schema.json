{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.routepilot.dev/v1/artifacts/evidence-bundle.v1.schema.json",
  "x-routepilot-contract": "EvidenceBundle@1",
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_type": {
          "enum": [
            "user",
            "agent",
            "service",
            "migration"
          ],
          "title": "Actor Type",
          "type": "string"
        },
        "actor_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Actor Id",
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "artifact_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_type",
        "artifact_id",
        "schema_version",
        "version"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ArtifactType": {
      "enum": [
        "TravelQuestion",
        "TravelAnswer",
        "TripBrief",
        "EvidenceBundle",
        "CandidateSet",
        "ItineraryPlan",
        "ConstraintReport",
        "SemanticRiskReport",
        "ValidationReport",
        "TripSnapshot",
        "ShareSnapshot"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "Citation": {
      "additionalProperties": false,
      "properties": {
        "citation_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Citation Id",
          "type": "string"
        },
        "evidence_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Evidence Id",
          "type": "string"
        },
        "title": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "locator": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "citation_id",
        "evidence_id",
        "title",
        "locator",
        "source"
      ],
      "title": "Citation",
      "type": "object"
    },
    "CoordinateSystem": {
      "enum": [
        "WGS84",
        "GCJ-02",
        "BD-09"
      ],
      "title": "CoordinateSystem",
      "type": "string"
    },
    "EvidenceClaim": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Claim Id",
          "type": "string"
        },
        "statement": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Statement",
          "type": "string"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Confidence"
        }
      },
      "required": [
        "claim_id",
        "statement",
        "confidence"
      ],
      "title": "EvidenceClaim",
      "type": "object"
    },
    "EvidenceConflict": {
      "additionalProperties": false,
      "properties": {
        "conflict_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Conflict Id",
          "type": "string"
        },
        "topic": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Topic",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
            "type": "string"
          },
          "maxItems": 20,
          "minItems": 2,
          "title": "Evidence Refs",
          "type": "array"
        },
        "detail": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "resolution_status": {
          "enum": [
            "unresolved",
            "resolved",
            "accepted_risk"
          ],
          "title": "Resolution Status",
          "type": "string"
        }
      },
      "required": [
        "conflict_id",
        "topic",
        "evidence_refs",
        "detail",
        "resolution_status"
      ],
      "title": "EvidenceConflict",
      "type": "object"
    },
    "EvidenceItem": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Evidence Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "poi",
            "area",
            "lodging_area",
            "opening_hours",
            "weather",
            "route",
            "price",
            "policy"
          ],
          "title": "Kind",
          "type": "string"
        },
        "title": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "summary": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "place_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaceRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "claims": {
          "items": {
            "$ref": "#/$defs/EvidenceClaim"
          },
          "maxItems": 100,
          "minItems": 1,
          "title": "Claims",
          "type": "array"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        },
        "freshness": {
          "$ref": "#/$defs/Freshness"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "kind",
        "title",
        "summary",
        "claims",
        "source",
        "freshness",
        "retrieved_at"
      ],
      "title": "EvidenceItem",
      "type": "object"
    },
    "Freshness": {
      "additionalProperties": false,
      "properties": {
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "valid_until": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid Until"
        },
        "status": {
          "$ref": "#/$defs/FreshnessStatus"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "observed_at",
        "status",
        "source"
      ],
      "title": "Freshness",
      "type": "object"
    },
    "FreshnessStatus": {
      "enum": [
        "fresh",
        "stale",
        "expired",
        "unknown"
      ],
      "title": "FreshnessStatus",
      "type": "string"
    },
    "GeoPoint": {
      "additionalProperties": false,
      "properties": {
        "latitude": {
          "anyOf": [
            {
              "maximum": 90.0,
              "minimum": -90.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Latitude"
        },
        "longitude": {
          "anyOf": [
            {
              "maximum": 180.0,
              "minimum": -180.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Longitude"
        },
        "coordinate_system": {
          "$ref": "#/$defs/CoordinateSystem"
        },
        "accuracy_meters": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Accuracy Meters"
        }
      },
      "required": [
        "latitude",
        "longitude",
        "coordinate_system"
      ],
      "title": "GeoPoint",
      "type": "object"
    },
    "PlaceRef": {
      "additionalProperties": false,
      "properties": {
        "place_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Place Id",
          "type": "string"
        },
        "display_name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "address": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Address"
        },
        "country_code": {
          "pattern": "^[A-Z]{2}$",
          "title": "Country Code",
          "type": "string"
        },
        "timezone": {
          "examples": [
            "Asia/Shanghai"
          ],
          "format": "iana-time-zone",
          "maxLength": 64,
          "minLength": 1,
          "title": "Timezone",
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/GeoPoint"
        },
        "provider_ids": {
          "items": {
            "$ref": "#/$defs/ProviderPlaceId"
          },
          "maxItems": 16,
          "title": "Provider Ids",
          "type": "array"
        },
        "source": {
          "$ref": "#/$defs/SourceRef"
        }
      },
      "required": [
        "place_id",
        "display_name",
        "country_code",
        "timezone",
        "location",
        "source"
      ],
      "title": "PlaceRef",
      "type": "object"
    },
    "ProviderPlaceId": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "place_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Place Id",
          "type": "string"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "place_id",
        "version"
      ],
      "title": "ProviderPlaceId",
      "type": "object"
    },
    "SourceKind": {
      "enum": [
        "user",
        "rag",
        "provider",
        "agent",
        "policy",
        "system"
      ],
      "title": "SourceKind",
      "type": "string"
    },
    "SourceRef": {
      "additionalProperties": false,
      "description": "A safe, versioned provenance pointer; never contains provider raw payloads.",
      "properties": {
        "source_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "title": "Source Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "uri": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "publisher": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Publisher"
        },
        "license": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        }
      },
      "required": [
        "source_id",
        "kind",
        "name",
        "version",
        "retrieved_at"
      ],
      "title": "SourceRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Artifact Id",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "reason": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "artifact_type": {
      "const": "EvidenceBundle",
      "title": "Artifact Type",
      "type": "string"
    },
    "trip_brief_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "timezone": {
      "examples": [
        "Asia/Shanghai"
      ],
      "format": "iana-time-zone",
      "maxLength": 64,
      "minLength": 1,
      "title": "Timezone",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceItem"
      },
      "maxItems": 1000,
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "citations": {
      "items": {
        "$ref": "#/$defs/Citation"
      },
      "maxItems": 1000,
      "title": "Citations",
      "type": "array"
    },
    "conflicts": {
      "items": {
        "$ref": "#/$defs/EvidenceConflict"
      },
      "maxItems": 200,
      "title": "Conflicts",
      "type": "array"
    }
  },
  "required": [
    "artifact_id",
    "schema_version",
    "version",
    "created_at",
    "created_by",
    "reason",
    "artifact_type",
    "trip_brief_ref",
    "timezone",
    "evidence"
  ],
  "title": "EvidenceBundle",
  "type": "object"
}
