        "status": {
          "enum": [
            "started",
            "progress",
            "completed",
            "failed"
          ],
          "title": "Status",
          "type": "string"
        },
        "duration_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Ms"
        },
        "sources": {
          "items": {
            "$ref": "#/$defs/PublicSourceSummary"
          },
          "maxItems": 50,
          "title": "Sources",
          "type": "array"
        },
        "control_version": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Control Version"
        }
      },
      "required": [
        "agent",
        "activity",
        "status"
