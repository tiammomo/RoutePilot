# =============================================================================
# moyuan-travel-agent Environment Variables Example
# =============================================================================
# Copy this file to `.env` and fill in real values.
# =============================================================================

# =============================================================================
# LLM Configuration (at least configure one provider)
# =============================================================================

# MiniMax (Anthropic-compatible)
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-cp-your-minimax-token
ANTHROPIC_DEFAULT_SONNET_MODEL=mimo-v2.5-pro

# Optional model aliases used by the Beijing travel data demo / Claude Code tooling.
ANTHROPIC_MODEL=mimo-v2.5-pro
ANTHROPIC_SMALL_FAST_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_OPUS_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_HAIKU_MODEL=mimo-v2.5-pro
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Optional OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key

# Optional Anthropic official
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# Moyuan Service Configuration
# =============================================================================

ENVIRONMENT=dev
MOYUAN_WEB_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:33003
MOYUAN_WEB_PORT=38083
MOYUAN_FRONTEND_PORT=33003
MOYUAN_REQUEST_TIMEOUT_SECONDS=30
MOYUAN_RATE_LIMIT_MAX_REQUESTS=100
MOYUAN_RATE_LIMIT_WINDOW_SECONDS=60
MOYUAN_METRICS_ENABLED=true
MOYUAN_METRICS_PATH=/api/metrics
MOYUAN_STRUCTURED_LOGGING=true
MOYUAN_FAIL_FAST_STARTUP_VALIDATION=false

# Optional Moyuan PostgreSQL runtime backend.
MOYUAN_DB_BACKEND=file
MOYUAN_POSTGRES_DSN=
MOYUAN_DB_POOL_MIN=1
MOYUAN_DB_POOL_MAX=5

# =============================================================================
# Beijing Travel / Hotel Data Demo Configuration
# =============================================================================

# Existing local databases can keep their current name if they already contain
# collected commute and hotel demo data. Fresh installs can use these defaults.
DATABASE_URL="postgresql://travelpilot:<replace-with-local-password>@127.0.0.1:35434/travelpilot?schema=public"
POSTGRES_DB="travelpilot"
POSTGRES_USER="travelpilot"
POSTGRES_PASSWORD="<replace-with-local-password>"
POSTGRES_PORT=35434

PROJECTS_DIR="./data/projects"
TRAVELPILOT_DATA_ROOT="./travel-data/processed"
TRAVELPILOT_WIKI_ROOT="./travel-data/wiki"
AMAP_API_KEY="replace-with-your-amap-key"

PORT=33003
WEB_PORT=33003
NEXT_PUBLIC_APP_URL="http://localhost:33003"
NEXT_PUBLIC_API_BASE=""
PREVIEW_PORT_START=4100
PREVIEW_PORT_END=4999

ENCRYPTION_KEY="replace-with-a-64-character-hex-secret"
API_TIMEOUT_MS=3000000
SKIP_DB_SYNC=0

# Codex CLI / OpenAI-compatible endpoint
CODEX_MODEL="gpt-5.5"
CODEX_MODEL_REASONING_EFFORT="low"
CODEX_OPENAI_BASE_URL="https://w.ciykj.cn"
CODEX_OPENAI_API_KEY="replace-with-your-openai-compatible-key"
CODEX_EXECUTABLE="codex"
CODEX_MAX_TURNS=20
CODEX_MAX_THINKING_TOKENS=4096
