# RoutePilot V1 direct-process configuration.
#
# Docker Compose users should copy deploy/compose/v1.env.example instead. Never
# commit a populated .env file. All keys and passwords below are server-only.

# -----------------------------------------------------------------------------
# Service and deployment
# -----------------------------------------------------------------------------
ENVIRONMENT=dev
ROUTEPILOT_DEPLOYMENT_ENV=local
MOYUAN_WEB_HOST=0.0.0.0
MOYUAN_WEB_PORT=38083
CORS_ORIGINS=http://127.0.0.1:33003

ROUTEPILOT_API_ORIGIN=http://127.0.0.1:38083
ROUTEPILOT_PUBLIC_ORIGIN=http://127.0.0.1:33003

# -----------------------------------------------------------------------------
# PostgreSQL and Redis
# Schema is managed only by deploy/migrations. RAG and A2A fall back to the V1
# DSN when their dedicated DSN is blank.
# -----------------------------------------------------------------------------
ROUTEPILOT_V1_DATABASE_URL=
ROUTEPILOT_RAG_DATABASE_URL=
ROUTEPILOT_A2A_DATABASE_URL=
ROUTEPILOT_OUTBOX_DATABASE_URL=
ROUTEPILOT_REDIS_URL=
ROUTEPILOT_SHARE_PEPPER=
# Optional. When set, enables /api/metrics and must contain at least 32 characters.
ROUTEPILOT_METRICS_TOKEN=

# External Run worker recovery. Reclaim idle should normally be >= lease.
ROUTEPILOT_V1_RUN_LEASE_SECONDS=60
ROUTEPILOT_V1_RUN_RECLAIM_IDLE_MILLISECONDS=60000

# -----------------------------------------------------------------------------
# Runtime and server-only travel providers
# -----------------------------------------------------------------------------
ROUTEPILOT_V1_EXECUTION_MODE=inline
ROUTEPILOT_V1_EXECUTION_PROFILE=v2_research_planning
# Optional and server-only. Put the real value in an ignored local env file;
# never use AMAP_API_KEY or a NEXT_PUBLIC_* variable.
ROUTEPILOT_AMAP_WEB_KEY=
ROUTEPILOT_PROVIDER_ALLOWLIST=amap
ROUTEPILOT_AMAP_HTTP_TIMEOUT_SECONDS=3.0

# Optional bounded model assistance for the Research Agent. The model output is
# only a short Provider/RAG query, never user-facing evidence or a final plan.
ROUTEPILOT_LLM_ENDPOINT=https://api.deepseek.com/chat/completions
ROUTEPILOT_LLM_API_KEY=
ROUTEPILOT_LLM_MODEL=deepseek-v4-flash
ROUTEPILOT_LLM_MAX_OUTPUT_TOKENS=96
ROUTEPILOT_ANSWER_MAX_OUTPUT_TOKENS=320

# RAG lexical search always remains explicit. Semantic retrieval additionally
# requires an OpenAI-compatible embeddings endpoint that returns exactly 384
# dimensions; when absent, retrieval reports lexical-only degradation.
ROUTEPILOT_RAG_CORPUS_REVISION=default
ROUTEPILOT_EMBEDDING_ENDPOINT=
ROUTEPILOT_EMBEDDING_API_KEY=
ROUTEPILOT_EMBEDDING_MODEL=
ROUTEPILOT_EMBEDDING_MODEL_VERSION=
ROUTEPILOT_EMBEDDING_DIMENSION=384
ROUTEPILOT_EMBEDDING_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Local-only BFF identity
# Generate ROUTEPILOT_V1_DEV_BFF_SECRET with at least 32 random bytes and use
# the same value in API and Web. Both dev-auth flags must be 0 outside local.
# -----------------------------------------------------------------------------
ROUTEPILOT_V1_DEV_AUTH=0
ROUTEPILOT_BFF_DEV_AUTH=0
ROUTEPILOT_V1_DEV_BFF_SECRET=
ROUTEPILOT_BFF_DEV_TENANT=local-tenant
ROUTEPILOT_BFF_DEV_USER=local-user
ROUTEPILOT_BFF_DEV_ROLES=owner

# -----------------------------------------------------------------------------
# OIDC API validation and Web Authorization Code + PKCE
# All endpoint URLs are explicit HTTPS URLs in staging/production. The cookie
# key is exactly 32 random bytes encoded as unpadded base64url.
# -----------------------------------------------------------------------------
ROUTEPILOT_OIDC_ISSUER=
ROUTEPILOT_OIDC_AUDIENCE=routepilot-api
ROUTEPILOT_OIDC_JWKS_URL=
ROUTEPILOT_OIDC_ALGORITHMS=RS256,ES256
ROUTEPILOT_OIDC_TENANT_CLAIM=tenant_id
ROUTEPILOT_OIDC_ROLES_CLAIM=roles
ROUTEPILOT_OIDC_AUTHORIZATION_EPOCH_CLAIM=authorization_epoch

ROUTEPILOT_OIDC_AUTHORIZATION_URL=
ROUTEPILOT_OIDC_TOKEN_URL=
ROUTEPILOT_OIDC_END_SESSION_URL=
ROUTEPILOT_OIDC_CLIENT_ID=routepilot-web
ROUTEPILOT_OIDC_CLIENT_SECRET=
ROUTEPILOT_OIDC_SCOPES=openid profile email offline_access
ROUTEPILOT_OIDC_COOKIE_KEY=
ROUTEPILOT_ACCESS_TOKEN_COOKIE_NAME=routepilot_access_token_dev

# -----------------------------------------------------------------------------
# Offline historical-data import only. This is not read by the product runtime.
# Use a read-only source credential; the tool never deletes source data.
# -----------------------------------------------------------------------------
ROUTEPILOT_LEGACY_DATABASE_URL=
