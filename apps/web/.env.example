# Server-only. Never rename these to NEXT_PUBLIC_*.
ROUTEPILOT_API_ORIGIN=http://127.0.0.1:38083
ROUTEPILOT_DEPLOYMENT_ENV=local
# Optional canonical browser origin behind a reverse proxy. When omitted, the
# BFF compares the Origin header with the request Host header.
# ROUTEPILOT_PUBLIC_ORIGIN=https://travel.example.com

# Local development identity injection is disabled unless all four values are set.
# Never enable it in production. The FastAPI process separately needs
# ROUTEPILOT_V1_DEV_AUTH=1; non-loopback container traffic is accepted only
# when the same ROUTEPILOT_V1_DEV_BFF_SECRET is presented.
ROUTEPILOT_BFF_DEV_AUTH=0
ROUTEPILOT_BFF_DEV_TENANT=local-tenant
ROUTEPILOT_BFF_DEV_USER=local-user
ROUTEPILOT_BFF_DEV_ROLES=owner
# Required only when local development identity injection is enabled. Generate
# at least 32 random bytes; never reuse this value outside one local stack.
ROUTEPILOT_V1_DEV_BFF_SECRET=

# This file defaults to a local HTTP-compatible name. Staging/production must use
# `__Host-routepilot_access_token` (the preprod Compose overlay sets it) and the
# BFF refuses any non-`__Host-` name there. Access JWT storage is always HttpOnly
# and SameSite=Strict; secure deployments additionally force Secure.
ROUTEPILOT_ACCESS_TOKEN_COOKIE_NAME=routepilot_access_token_dev

# OIDC is mandatory in staging/production. It can be exercised locally by setting
# ROUTEPILOT_OIDC_ENABLED=1 and disabling development identity. Endpoints are
# explicit by design: discovery is not fetched and redirects are not followed.
ROUTEPILOT_OIDC_ENABLED=0
ROUTEPILOT_OIDC_ISSUER=https://identity.example.com/
ROUTEPILOT_OIDC_AUTHORIZATION_URL=https://identity.example.com/oauth2/authorize
ROUTEPILOT_OIDC_TOKEN_URL=https://identity.example.com/oauth2/token
ROUTEPILOT_OIDC_END_SESSION_URL=https://identity.example.com/oauth2/logout
ROUTEPILOT_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
ROUTEPILOT_OIDC_CLIENT_ID=routepilot-web
ROUTEPILOT_OIDC_CLIENT_SECRET=
ROUTEPILOT_OIDC_SCOPES=openid profile email offline_access
ROUTEPILOT_OIDC_ALGORITHMS=RS256,ES256
# Exactly 32 random bytes encoded as unpadded base64url. Never reuse it.
ROUTEPILOT_OIDC_COOKIE_KEY=
