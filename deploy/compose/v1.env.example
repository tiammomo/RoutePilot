# Copy to an ignored local env file and fill every blank secret with an
# independently generated random value. Blank values intentionally make
# `docker compose config` and startup fail closed.

ROUTEPILOT_IMAGE_TAG=local
ROUTEPILOT_POSTGRES_PORT=35434
ROUTEPILOT_REDIS_PORT=36379
ROUTEPILOT_API_PORT=38083
ROUTEPILOT_WEB_PORT=33003

# Generate independent 32-byte hex values (for example: `openssl rand -hex 32`).
ROUTEPILOT_POSTGRES_ADMIN_PASSWORD=
ROUTEPILOT_MIGRATION_DB_PASSWORD=
ROUTEPILOT_API_DB_PASSWORD=
ROUTEPILOT_WORKER_DB_PASSWORD=
ROUTEPILOT_OUTBOX_DB_PASSWORD=
ROUTEPILOT_REDIS_PASSWORD=
ROUTEPILOT_V1_DEV_BFF_SECRET=
ROUTEPILOT_SHARE_PEPPER=
# Optional server-only AMap Web Service key. Keep this blank in the committed
# example and set it only in the ignored deploy/compose/.env.v1.local file.
ROUTEPILOT_AMAP_WEB_KEY=
# Optional bounded Research directive: one call per new Run, thinking disabled.
ROUTEPILOT_LLM_ENDPOINT=https://api.deepseek.com/chat/completions
ROUTEPILOT_LLM_API_KEY=
ROUTEPILOT_LLM_MODEL=deepseek-v4-flash
ROUTEPILOT_LLM_MAX_OUTPUT_TOKENS=96
ROUTEPILOT_ANSWER_MAX_OUTPUT_TOKENS=320
# Used only by the built-in Web OIDC BFF in pre-production. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ROUTEPILOT_OIDC_COOKIE_KEY=
ROUTEPILOT_OIDC_CLIENT_SECRET=
ROUTEPILOT_V1_RUN_LEASE_SECONDS=60
ROUTEPILOT_V1_RUN_RECLAIM_IDLE_MILLISECONDS=60000
ROUTEPILOT_EMBEDDING_ENDPOINT=
ROUTEPILOT_EMBEDDING_API_KEY=
ROUTEPILOT_EMBEDDING_MODEL=
ROUTEPILOT_EMBEDDING_MODEL_VERSION=

# Local-only server-derived identity. Never enable this path in pre-production.
ROUTEPILOT_DEV_TENANT=local-tenant
ROUTEPILOT_DEV_USER=local-user

# Used only with v1.preprod.yaml. These endpoint/identifier values are not bearer secrets.
ROUTEPILOT_OIDC_ISSUER=https://identity.example.invalid/
ROUTEPILOT_OIDC_AUDIENCE=routepilot-api
ROUTEPILOT_OIDC_JWKS_URL=https://identity.example.invalid/.well-known/jwks.json
ROUTEPILOT_OIDC_AUTHORIZATION_URL=https://identity.example.invalid/oauth2/authorize
ROUTEPILOT_OIDC_TOKEN_URL=https://identity.example.invalid/oauth2/token
ROUTEPILOT_OIDC_END_SESSION_URL=https://identity.example.invalid/oauth2/logout
ROUTEPILOT_OIDC_CLIENT_ID=routepilot-web
ROUTEPILOT_OIDC_SCOPES=openid profile email offline_access
ROUTEPILOT_OIDC_ALGORITHMS=RS256,ES256
ROUTEPILOT_PUBLIC_ORIGIN=https://travel.example.invalid
