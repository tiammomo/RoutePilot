{
  "schemaVersion": 1,
  "policy": {
    "targetCoreSkillCount": 11,
    "allowLegacyAliases": true,
    "installLegacyByDefault": false,
    "packageFormat": "tgz",
    "packageDir": ".claude/skill-packages",
    "description": "QuantPilot skills 以少量核心能力为主，旧目录先作为兼容别名保留。新增能力优先并入核心 skill。"
  },
  "coreSkills": [
    {
      "id": "quant-run-planner",
      "name": "运行规划",
      "version": "0.2.0",
      "status": "stable",
      "boundary": "意图澄清、澄清承接、任务拆解、run_plan 生成和执行顺序控制。",
      "inputs": ["用户问题", ".quantpilot/manifest.json", "上一轮 run_plan"],
      "outputs": [".quantpilot/run_plan.json", ".quantpilot/events.jsonl"],
      "scripts": ["scripts/intent_clarifier.py"],
      "validation": ["不清晰任务必须停在 needs_clarification", "清晰任务必须进入 planned"]
    },
    {
      "id": "quant-data-registry",
      "name": "数据注册与信源选择",
      "version": "0.2.0",
      "status": "stable",
      "boundary": "查询后端数据能力、候选信源、缓存、主备源、字段补数和降级规则。",
      "inputs": ["run_plan", "后端 /api/v1/registry", "后端 /api/v1/provider-candidates", "docs/market-data-source-knowledge.md"],
      "outputs": ["数据源选择说明", "候选源限制说明", "字段补数计划"],
      "validation": ["必须说明 source、as_of、fetched_at 和 data_quality", "历史 K 线补数必须说明字段来源和 provider 边界"]
    },
    {
      "id": "quant-symbol-resolver",
      "name": "标的解析",
      "version": "0.1.0",
      "status": "stable",
      "boundary": "把中文简称、代码、指数、ETF 转为标准证券代码、市场和资产类型。",
      "inputs": ["用户问题", "候选标的文本"],
      "outputs": ["symbols", "resolvedSymbols"],
      "validation": ["run_plan.symbols 必须是代码字符串数组"]
    },
    {
      "id": "quant-image-extraction",
      "name": "图片提取",
      "version": "0.1.0",
      "status": "stable",
      "boundary": "读取用户上传的图片附件清单，校验图片文件，抽取或标注持仓截图中的资产、股票、成本、盈亏、现金和仓位字段。",
      "inputs": [".quantpilot/attachments.json", "uploaded images", "用户问题"],
      "outputs": ["evidence/image_extraction.json", "dashboard-data.json.imageExtraction"],
      "endpoints": ["mcp__QuantPilotImage__quant_extract_uploaded_image", "mcp__MiniMax__understand_image"],
      "validation": [
        "图片任务必须先调用 quant-image-extraction",
        "无法识别的截图字段必须写 null 并列入 needs_manual_confirmation",
        "不得编造截图中的持仓、成本、现金或盈亏"
      ]
    },
    {
      "id": "quant-market-data",
      "name": "行情数据",
      "version": "0.3.0",
      "status": "stable",
      "boundary": "实时行情、历史 K 线、指数/ETF、批量行情、多源 fallback 和本地字段补数。",
      "inputs": ["symbols", "timeRange", "period", "adjustment"],
      "outputs": ["quote", "kline.bars", "assets[]", "field_enrichment"],
      "endpoints": [
        "GET /api/v1/quotes/realtime/{symbol}",
        "POST /api/v1/quotes/realtime",
        "GET /api/v1/quotes/history/{symbol}",
        "POST /api/v1/ingestion/baostock/history",
        "POST /api/v1/ingestion/akshare/history",
        "GET /api/v1/provider-candidates"
      ],
      "legacyAliases": ["quant-a-share-history", "quant-index-etf-market", "quant-comparison"],
      "validation": ["趋势类任务必须有 K 线或明确的 K 线错误面板", "成交额、换手率和振幅缺失时必须说明补数状态"]
    },
    {
      "id": "quant-fundamentals",
      "name": "基本面与事件",
      "version": "0.1.0",
      "status": "planned",
      "boundary": "财务报表、财务衍生指标、公告和事件上下文。",
      "inputs": ["symbols", "reportPeriods"],
      "endpoints": [
        "GET /api/v1/fundamentals/financials/{symbol}",
        "GET /api/v1/indicators/fundamental/{symbol}",
        "GET /api/v1/events/announcements/{symbol}"
      ],
      "legacyAliases": [
        "quant-fundamental-financials",
        "quant-fundamental-indicators",
        "quant-announcement-events"
      ],
      "outputs": ["financials", "fundamentalIndicators", "announcements", "valuation"],
      "scripts": ["scripts/valuation_scenarios.py"],
      "validation": ["必须说明报告期、缺失字段和数据来源", "估值情景必须展示假设、缺失字段和非投资建议限制"]
    },
    {
      "id": "quant-indicators",
      "name": "指标计算",
      "version": "0.1.0",
      "status": "planned",
      "boundary": "技术指标、收益、波动、最大回撤、成交量、相关性、流动性和风险指标计算。",
      "inputs": ["kline.bars", "assets[]"],
      "outputs": ["technicalIndicators", "computedMetrics", "riskMetrics", "correlation", "liquidity", "trendTemplate"],
      "endpoints": ["GET /api/v1/indicators/technical/{symbol}"],
      "legacyAliases": ["quant-technical-indicators"],
      "scripts": ["scripts/correlation.py", "scripts/liquidity.py", "scripts/trend_template.py"],
      "validation": ["必须明确样本长度和计算口径", "多标的任务必须计算相关性或说明样本不足", "流动性摘要必须说明成交额窗口和代理口径", "调仓/趋势任务必须输出趋势模板或说明样本不足"]
    },
    {
      "id": "quant-backtest",
      "name": "回测复盘",
      "version": "0.1.0",
      "status": "stable",
      "boundary": "策略参数、回测执行、净值曲线、回撤、交易明细和限制说明。",
      "inputs": ["symbols", "strategyParams", "kline.bars"],
      "outputs": ["backtest", "trades", "equityCurve"],
      "endpoints": ["GET /api/v1/backtests/ma-crossover/{symbol}"],
      "validation": ["必须说明费用、样本、滑点和策略限制"]
    },
    {
      "id": "quant-data-quality",
      "name": "数据质量",
      "version": "0.2.0",
      "status": "stable",
      "boundary": "证据文件、来源、时效、缺失字段、异常值和限制说明。",
      "inputs": ["raw data", "dashboard-data.json", "run_plan"],
      "outputs": ["evidence/sources.json", "evidence/data_quality.json"],
      "validation": ["每个展示数据必须可追溯到 source"]
    },
    {
      "id": "quantpilot-ui-product-design",
      "name": "平台 UI 产品设计",
      "version": "0.2.0",
      "status": "stable",
      "boundary": "QuantPilot 主平台页面、组件、控制台、设置、列表、导航、状态和响应式体验设计，不负责生成工作空间金融看板。",
      "inputs": ["src/app 页面", "src/components 组件", "docs/ui-shadcn-migration.md", "现有设计 token"],
      "outputs": ["平台 React/Tailwind UI", "可复用组件", "页面状态和响应式布局"],
      "validation": ["必须复用现有 UI/quant primitives", "必须覆盖 loading/empty/error/disabled/long text 状态", "必须通过 lint 和 type-check"]
    },
    {
      "id": "quant-visualization-html",
      "name": "可视化看板",
      "version": "0.3.4",
      "status": "stable",
      "boundary": "基于已验证 final 数据和场景模板生成 Next.js 金融分析看板。",
      "inputs": ["data_file/final/dashboard-data.json", "evidence", "run_plan"],
      "outputs": ["app/page.tsx", "app/globals.css", "visualization.template_id"],
      "validation": ["页面必须绑定真实数据", "必须包含图表、来源、加载/错误/空状态", "必须按 visualization.templateId 覆盖对应场景的必备组件", "动态 JSON 渲染必须使用 JsonRecord/asRecord/asArray 守卫并通过 Next.js build", "不得引用外部 CDN/远程资源、不得保留 mock/static 数据、不得写入明文密钥"]
    }
  ],
  "legacyAliases": {
    "quant-a-share-history": "quant-market-data",
    "quant-index-etf-market": "quant-market-data",
    "quant-comparison": "quant-market-data",
    "quant-fundamental-financials": "quant-fundamentals",
    "quant-fundamental-indicators": "quant-fundamentals",
    "quant-announcement-events": "quant-fundamentals",
    "quant-technical-indicators": "quant-indicators"
  }
}
